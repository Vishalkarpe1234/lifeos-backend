# Application
APP_NAME="Vishal Karpe Professional LifeOS"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://lifeos_user:lifeos_password@localhost:5432/lifeos_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=lifeos-storage
AWS_REGION=ap-south-1

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000

# Admin
ADMIN_EMAIL=admin@lifeos.app
ADMIN_PASSWORD=change-this-password

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
